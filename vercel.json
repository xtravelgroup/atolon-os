{
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "atolon.co" }],
      "destination": "https://atoloncartagena.com",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.atolon.co" }],
      "destination": "https://atoloncartagena.com",
      "permanent": false
    },
    { "source": "/wa/vip",        "destination": "/booking?tipo=vip-pass&utm_source=whatsapp&utm_medium=directo&utm_campaign=vip-pass",                "permanent": false },
    { "source": "/wa/exclusive",  "destination": "/booking?tipo=exclusive-pass&utm_source=whatsapp&utm_medium=directo&utm_campaign=exclusive-pass",  "permanent": false },
    { "source": "/wa/experience", "destination": "/booking?tipo=atolon-experience&utm_source=whatsapp&utm_medium=directo&utm_campaign=atolon-experience", "permanent": false },
    { "source": "/wa/after",      "destination": "/booking?tipo=after-island&utm_source=whatsapp&utm_medium=directo&utm_campaign=after-island",      "permanent": false },
    { "source": "/wa/consulta",   "destination": "/booking?utm_source=whatsapp&utm_medium=directo&utm_campaign=consulta",  "permanent": false },
    { "source": "/wa/promo",      "destination": "/booking?utm_source=whatsapp&utm_medium=directo&utm_campaign=promo",     "permanent": false },
    { "source": "/wa/followup",   "destination": "/booking?utm_source=whatsapp&utm_medium=directo&utm_campaign=followup",  "permanent": false },
    { "source": "/wa/grupo",      "destination": "/booking?utm_source=whatsapp&utm_medium=directo&utm_campaign=grupo",     "permanent": false }
  ],
  "rewrites": [
    { "source": "/iclock/:op*", "destination": "/api/zk-iclock?_zkop=:op*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/((?!assets/|favicon|.*\\.(?:js|css|png|jpg|jpeg|gif|svg|webp|ico|woff|woff2|ttf|otf|map)$).*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/update-tasa",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/daily-resultados",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/sync-loggro",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/zoho-poll",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/wompi-poll",
      "schedule": "*/5 * * * *"
    }
  ]
}
